# ─────────────────────────────────────────────────────────────
# Uncommon Records — environment variables
# Copy to .env.local for local dev; set the same keys in Vercel.
# ─────────────────────────────────────────────────────────────

# --- Auth ---
# Long random string. Generate: openssl rand -hex 32
JWT_SECRET=change-me-in-production
JWT_EXPIRY_DAYS=7

# --- Database (Supabase Postgres) ---
# From Supabase dashboard › Connect › Prisma. Use the Transaction pooler (6543) for
# the app (serverless-friendly) and the Session pooler (5432) for migrations.
# App runtime (transaction pooler):
DATABASE_URL="postgresql://postgres.[REF]:[PWD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Migrations (session pooler):
DIRECT_URL="postgresql://postgres.[REF]:[PWD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# --- Object storage (S3 or Cloudflare R2) ---
# For AWS S3: leave S3_ENDPOINT empty, set S3_REGION.
# For Cloudflare R2: set S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com and S3_REGION=auto
S3_ENDPOINT=https://6864227c9aced9e1d70dc269f2f65b83.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=uncommonrecords
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Public base URL files are served from (CDN / R2 public domain / bucket website).
# Example R2: https://pub-xxxx.r2.dev   Example S3: https://uncommon-uploads.s3.eu-west-3.amazonaws.com
S3_PUBLIC_BASE_URL=

# --- Mail (SMTP, for invitations + newsletter) ---
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=noreply@uncommon-records.fr

# --- App ---
# Public URL of the deployment, used to build invite / promo links.
FRONTEND_URL=http://localhost:3000
INVITE_TOKEN_TTL=48
# Default admin bootstrap (used by the seed script)
ADMIN_EMAIL=admin@uncommon-records.fr
ADMIN_PASSWORD=UncommonAdmin2024!
AUTO_SEED_DEMO=true
